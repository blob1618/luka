# Meta WhatsApp API Configuration
WHATSAPP_VERIFY_TOKEN=your_custom_verify_token_here
WHATSAPP_API_TOKEN=your_meta_permanent_or_temporary_token
WHATSAPP_PHONE_ID=your_whatsapp_phone_number_id

# LLM Provider Configuration
# Options: gemini, mistral
LLM_PROVIDER=gemini

# LLM Configuration (Gemini)
# Gemini Configuration
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash

# Mistral Configuration
MISTRAL_API_KEY=your-mistral-api-key
MISTRAL_MODEL=mistral-small-latest

# Database Configuration
DATABASE_URL=sqlite:///./luka.db
# For PostgreSQL use something like:
# DATABASE_URL=postgresql://user:password@localhost:5432/luka

# Redis Configuration
# Optional locally. Required/recommended for deployed environments that use Redis-backed features.
REDIS_URL=redis://localhost:6379

# WhatsApp Onboarding Configuration
ONBOARDING_REGISTRATION_URL=http://localhost:8000/registro
ONBOARDING_INVITATION_TTL_MINUTES=30
ONBOARDING_RESEND_COOLDOWN_SECONDS=60
ONBOARDING_MAX_RESENDS=3
